# Шаблон секретов. Скопируйте в .env (.env в .gitignore — не попадёт в git).
# НИКОГДА не коммитьте реальный .env.

# --- Postgres ---
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me_random_string
POSTGRES_DB=appdb
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://app:change_me_random_string@localhost:5432/appdb
POSTGRES_READONLY_URL=postgresql://readonly:change_me@localhost:5432/appdb

# --- GitHub (для MCP) ---
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Anthropic (опционально, если AI-функционал в проекте) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- ntfy.sh (уведомления) ---
NTFY_TOPIC_URL=https://ntfy.sh/your-unique-topic-name-here-min-20-chars
# Совет: используйте длинное случайное имя topic — это и есть защита (никто не угадает)

# --- Профиль торгового терминала (если активен) ---
TINKOFF_INVEST_TOKEN=
MOEX_API_KEY=

# --- Профиль 44-ФЗ бота (если активен) ---
ZAKUPKI_GOV_API_TOKEN=

# --- ЮKassa (если включена монетизация) ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# --- Окружение ---
ENVIRONMENT=development
LOG_LEVEL=DEBUG
